import pandas as pd
import numpy as np
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense

# Create dataset
data = {
    'age': [18,22,25,30,35,40,45,50],
    'weight': [50,60,65,70,75,80,85,90],
    'height': [155,160,165,170,172,175,178,180],
    'activity': [1.2,1.375,1.55,1.55,1.725,1.725,1.9,1.9],
    'calories': [1700,1900,2100,2300,2500,2700,2900,3100]
}

df = pd.DataFrame(data)

X = df[['age','weight','height','activity']]
y = df['calories']

# Build model
model = Sequential()
model.add(Dense(16, input_dim=4, activation='relu'))
model.add(Dense(8, activation='relu'))
model.add(Dense(1))

model.compile(optimizer='adam', loss='mse')

# Train model
model.fit(X, y, epochs=100)

# Save model
model.save("calorie_mlp.keras")

print("Model trained and saved!")
